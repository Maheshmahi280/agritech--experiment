# AgriConnect Environment Configuration Template
# Copy this file to .env and fill in actual values for your deployment
# NEVER commit the actual .env file to version control

# ============================================================================
# DJANGO SETTINGS
# ============================================================================

# Django secret key (generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
# REQUIRED: Change this for production
SECRET_KEY=your-secret-key-here-generate-with-get-random_secret_key

# Debug mode (True for development, False for production)
DEBUG=False

# ALLOWED_HOSTS: comma-separated list of allowed hostnames
# For Hugging Face Spaces: space-id.hf.space
# For Render: app-name.onrender.com
# For local development: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,.hf.space,.onrender.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database URL (SQLite is default, works everywhere)
# SQLite: sqlite:////app/db.sqlite3
# PostgreSQL: postgresql://user:password@hostname:5432/database_name
DATABASE_URL=sqlite:////app/db.sqlite3

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================

# Deployment platform (used for configuration selection)
# Options: development, huggingface, render, heroku, docker, other
DEPLOYMENT_PLATFORM=docker

# Environment name (for logging and monitoring)
# Options: development, staging, production
ENVIRONMENT=production

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# CSRF trusted origins (comma-separated, for cross-origin requests)
# Format: https://yourdomain.com,https://subdomain.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://localhost:8000,https://127.0.0.1:8000

# Secure browser session (set to True in HTTPS production)
SESSION_COOKIE_SECURE=False

# HTTP only cookies (set to True in production)
SESSION_COOKIE_HTTPONLY=True

# HSTS max age (set to > 0 in production to enable HSTS)
SECURE_HSTS_SECONDS=0

# ============================================================================
# STATIC AND MEDIA FILES
# ============================================================================

# Static files directory
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles

# Media files directory
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# ============================================================================
# LOGGING AND MONITORING
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Sentry error tracking (optional, set if using Sentry)
SENTRY_DSN=

# ============================================================================
# APPLICATION-SPECIFIC SETTINGS
# ============================================================================

# Test mode flag (set to true when running tests)
TEST_MODE=False

# Maximum harvest items to display in UI
MAX_HARVEST_ITEMS=100

# Session timeout (in seconds, 3600 = 1 hour)
SESSION_TIMEOUT=3600

# ============================================================================
# HACKATHON ENVIRONMENT (Optional)
# ============================================================================

# Enable hackathon environment
HACKATHON_ENABLED=True

# Hackathon mode (sandbox or live)
HACKATHON_MODE=sandbox

# ============================================================================
# NOTES FOR DIFFERENT DEPLOYMENTS
# ============================================================================

# For Hugging Face Spaces:
#   1. Set DEBUG=False
#   2. Set ALLOWED_HOSTS=space-id.hf.space
#   3. Use DATABASE_URL=sqlite:////app/db.sqlite3 (shared storage)
#   4. All your secrets must be added in Hugging Face UI

# For Render.com:
#   1. Set DEBUG=False
#   2. Set ALLOWED_HOSTS=app-name.onrender.com
#   3. Set DATABASE_URL to PostgreSQL connection string from Render
#   4. Environment variables set in Render dashboard

# For Docker/Local:
#   1. Copy to .env and customize
#   2. Run: docker-compose up
#   3. Access at http://localhost:8000

# For Development:
#   1. Set DEBUG=True
#   2. Set ALLOWED_HOSTS=localhost,127.0.0.1
#   3. Leave other settings as defaults for development

# ============================================================================
# HOW TO GENERATE SECRET_KEY
# ============================================================================
# python manage.py shell
# >>> from django.core.management.utils import get_random_secret_key
# >>> print(get_random_secret_key())
# Copy the output and set SECRET_KEY in .env
